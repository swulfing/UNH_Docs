salaryMF$SEXE[salaryMF$SEXE == ""] <- NA
###Michael Thompson : WORKING
for (i in 1:length(salaryMF$TAIA2)){
if(is.na(salaryMF$ANARANY[i]) == TRUE & is.na(salaryMF$TAIA[i]) == TRUE){
