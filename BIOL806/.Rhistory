library(ggplot2)
N <- vector("numeric", length = 50)
for (i in 1:50){
N[1] <- .1
N[i+1] <- N[i] + .4*N[i]*(1 - N[i]/1)
}
popdata <- data.frame(1:51, N)
ggplot(popdata)
View(popdata)
ggplot(popdata, aes(x = X1.51, y = N)) +
geom_point()
N <- vector("numeric", length = 50)
for (i in 1:50){
N[1] <- .1
N[i+1] <- N[i] + .4*N[i]*(1 - N[i]/1)
}
popdata <- data.frame(1:51, N)
ggplot(popdata, aes(x = X1.51, y = N)) +
geom_point() +
geom_line(color = "black") +
ggtitle("R = 0.4") +
xlab("Year") + ylab("Population")
