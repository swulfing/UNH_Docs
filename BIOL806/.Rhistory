Baseball <- c("Boston Red Sox", "Toronto Blue Jays", "Tampa Bay Rays",
"Baltimore Orioles", "New York Yankees")
ALL_POSSIBLE_MATCHUPS <- NULL
k <- 1
for (i in 1:(length(Baseball) - 1)){
for(j in (i +1):length(Baseball)){
Baseball[k] <- paste(Baseball[i],
"versus", Baseball[j])
}
}
Baseball <- c("Boston Red Sox", "Toronto Blue Jays", "Tampa Bay Rays",
"Baltimore Orioles", "New York Yankees")
ALL_POSSIBLE_MATCHUPS <- NULL
k <- 1
for (i in 1:(length(Baseball) - 1)){
for(j in (i +1):length(Baseball)){
Baseball[k] <- paste(Baseball[i],
"versus", Baseball[j])
k <- k+1
}
}
Baseball <- c("Boston Red Sox", "Toronto Blue Jays", "Tampa Bay Rays",
"Baltimore Orioles", "New York Yankees")
ALL_POSSIBLE_MATCHUPS <- NULL
k <- 1
for (i in 1:(length(Baseball) - 1)){
for(j in (i +1):length(Baseball)){
ALL_POSSIBLE_MATCHUPS[k] <- paste(Baseball[i],
"versus", Baseball[j])
k <- k+1
}
}
ALL_POSSIBLE_MATCHUPS
download.file("https://raw.githubusercontent.com/swcarpentry/r-novice-gapminder/gh-pages/_episodes_rmd/data/gapminder_data.csv", destfile = "data/gapminder_data.csv")
setwd("~/UNH_Docs/BIOL806")
gapminder <- read.csv("09.16_PlottinginR/data/gapminder_data.csv", stringsAsFactors = TRUE)
require(dplyr)
require(tidyr)
gapminder_means <- gapminder %>%
select(country, pop) %>%
group_by(country)
gapminder_means <- gapminder %>%
select(country, pop) %>%
group_by(country) %>% #Doesn't quite do anything yet, just secretly stores as different data sets.
summarize(mean_pop = mean(pop))
gapminder_means
gapminder_means <- gapminder %>%
select(country, pop) %>%
group_by(country) %>% #Doesn't quite do anything yet, just secretly stores as different data sets.
summarize(mean_pop = mean(pop), sd_pop = sd(pop))
gapminder_means
gapminder_means <- gapminder %>%
select(country, pop) %>%
filter(pop > 1000000) %>%
group_by(country) %>% #Doesn't quite do anything yet, just secretly stores as different data sets.
summarize(mean_pop = mean(pop), sd_pop = sd(pop))
gapminder_means
gapminder_means$new_col <- gapminder_means$mean_pop^2
gapminder_means
