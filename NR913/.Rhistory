library(R2jags)
library(memisc)
library(pander)
setwd("~/UNH_Docs/NR913")
mass   <- c(6, 8,5,7,9,11)
pop    <- factor(c(1,1,2,2,3,3))
region <- factor(c(1,1,1,1,2,2))
hab    <- factor(c(1,2,3,1,2,3))
svl    <- c(40, 45,39,50,52,57)
data <- cbind(mass,pop,region,hab,svl)
lm(mass ~ pop * svl)
fm <- lm(mass ~ pop * svl) # Refit model
#lm(mass ~ pop + svl + pop:svl) #This is going to mean the same thing
model.matrix(fm)
#Now to make partial interaction effects
X <- model.matrix(fm)[,2:6]
X
#Now to make partial interaction effects
X <- model.matrix(fm)[,2:5]
X
#Now to make partial interaction effects
X <- model.matrix(fm)[,2:6]
X
X[3,3]
X[4,3]
X[3:4,3] <- 0
X
#Now to make partial interaction effects
X <- model.matrix(fm)[,2:5]
X[3:4,3] <- 0
X
new_m <- lm(mass~X)
new_m
model.matrix(new_m)
plot(svl, mass, col = c(rep("red", 2), rep("blue", 2), rep("green", 2)))
abline(new_m$coef[1], new_m$coef[4], col = "red")
abline(new_m$coef[1]+ new_m$coef[2], new_m$coef[4] + new_m$coef[5], col = "blue")
plot(svl, mass, col = c(rep("red", 2), rep("blue", 2), rep("green", 2)))
abline(new_m$coef[1], new_m$coef[4], col = "red")
plot(svl, mass, col = c(rep("red", 2), rep("blue", 2), rep("green", 2)))
abline(new_m$coef[1], new_m$coef[4], col = "red")
summary(new_m)
new$coef[2]
